# Security
LEARN2MASTER_SECRET_KEY=generate-a-long-random-string
LEARN2MASTER_DEBUG=0
LEARN2MASTER_FORCE_HTTPS=0
LEARN2MASTER_CSRF_ENABLED=1

# Database Configuration
# Local development can omit DATABASE_URL or use SQLite.
# Render/Supabase production must use the Supabase PostgreSQL connection string.
DATABASE_URL=sqlite:///learn2master.db

# Secure production bootstrap users. Required only when running:
# python manage.py create-initial-users
LEARN2MASTER_BOOTSTRAP_SCHOOL_NAME=Your School Name
LEARN2MASTER_SUPER_ADMIN_USERNAME=superadmin
LEARN2MASTER_SUPER_ADMIN_EMAIL=superadmin@example.com
LEARN2MASTER_SUPER_ADMIN_FULL_NAME=System Owner
LEARN2MASTER_SUPER_ADMIN_PASSWORD=change-this-long-random-password
LEARN2MASTER_SCHOOL_ADMIN_USERNAME=schooladmin
LEARN2MASTER_SCHOOL_ADMIN_EMAIL=schooladmin@example.com
LEARN2MASTER_SCHOOL_ADMIN_FULL_NAME=School Administrator
LEARN2MASTER_SCHOOL_ADMIN_PASSWORD=change-this-long-random-password
LEARN2MASTER_TEACHER_USERNAME=teacher
LEARN2MASTER_TEACHER_EMAIL=teacher@example.com
LEARN2MASTER_TEACHER_FULL_NAME=Lead Teacher
LEARN2MASTER_TEACHER_PASSWORD=change-this-long-random-password

# Demo seed passwords. Required only when running:
# python manage.py seed-demo-data
LEARN2MASTER_SEED_LEARNER_PASSWORD=change-this-demo-password
LEARN2MASTER_SEED_TEACHER_PASSWORD=change-this-demo-password
LEARN2MASTER_SEED_SCHOOL_ADMIN_PASSWORD=change-this-demo-password
LEARN2MASTER_SEED_SUPER_ADMIN_PASSWORD=change-this-demo-password

# AI API Keys
GROQ_API_KEY=your_groq_api_key_here
HF_TOKEN=your_huggingface_token_here
TRAINING_API_URL=https://your-training-feedback-endpoint.com/log

# Supabase Auth is not used. Supabase is used through DATABASE_URL as PostgreSQL.
