# Security
LEARN2MASTER_SECRET_KEY=generate-a-long-random-string
LEARN2MASTER_DEBUG=0
LEARN2MASTER_FORCE_HTTPS=0
LEARN2MASTER_CSRF_ENABLED=1

# Database Configuration
# For Supabase, use your connection string: postgresql://postgres.user:pass@host:5432/postgres
DATABASE_URL=sqlite:///learn2master.db

# AI API Keys
GROQ_API_KEY=your_groq_api_key_here
HF_TOKEN=your_huggingface_token_here
TRAINING_API_URL=https://your-training-feedback-endpoint.com/log

# Supabase Integration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key
